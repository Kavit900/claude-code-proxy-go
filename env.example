# ── free-claude-code Go proxy — .env.example ──────────────────────────────────
# Copy to .env and fill in your values.
# All fields are optional; the proxy will warn if no MODEL is set.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8082
HOST=0.0.0.0

# ── Model routing ─────────────────────────────────────────────────────────────
# Format: <provider>/<model-name>
# Supported providers: nvidia_nim | open_router | lmstudio | llamacpp | deepseek
#
# claude-3-opus-*  requests → MODEL_OPUS
# claude-*sonnet-* requests → MODEL_SONNET
# claude-*haiku-*  requests → MODEL_HAIKU
# everything else  requests → MODEL (fallback)

# NVIDIA NIM (40 req/min free — recommended)
NVIDIA_NIM_API_KEY=nvapi-your-key-here
MODEL_OPUS=nvidia_nim/z-ai/glm4.7
MODEL_SONNET=nvidia_nim/moonshotai/kimi-k2-thinking
MODEL_HAIKU=nvidia_nim/stepfun-ai/step-3.5-flash
MODEL=nvidia_nim/z-ai/glm4.7

# OpenRouter (hundreds of free models — uncomment to use)
# OPENROUTER_API_KEY=sk-or-your-key-here
# MODEL_OPUS=open_router/deepseek/deepseek-r1-0528:free
# MODEL_SONNET=open_router/openai/gpt-oss-120b:free
# MODEL_HAIKU=open_router/stepfun/step-3.5-flash:free
# MODEL=open_router/stepfun/step-3.5-flash:free

# LM Studio — fully local, no API key needed
# MODEL_OPUS=lmstudio/unsloth/MiniMax-M2.5-GGUF
# MODEL_SONNET=lmstudio/unsloth/Qwen3.5-35B-A3B-GGUF
# MODEL_HAIKU=lmstudio/unsloth/GLM-4.7-Flash-GGUF
# MODEL=lmstudio/unsloth/Qwen3.5-35B-A3B-GGUF

# llama.cpp — fully local, no API key needed
# MODEL=llamacpp/your-model-name

# DeepSeek
# DEEPSEEK_API_KEY=your-key-here
# MODEL=deepseek/deepseek-chat

# ── Provider base URLs (override defaults) ────────────────────────────────────
# NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# LMSTUDIO_BASE_URL=http://localhost:1234/v1
# LLAMACPP_BASE_URL=http://localhost:8080/v1

# ── Proxy (optional, for NVIDIA NIM requests) ─────────────────────────────────
# PROXY_URL=http://user:pass@proxy:8080
# PROXY_URL=socks5://user:pass@proxy:1080

# ── Rate limiting ─────────────────────────────────────────────────────────────
# RPM_LIMIT=40          # override per-provider default (requests per minute)
# MAX_CONCURRENT=5      # max simultaneous upstream requests (0 = unlimited)

# ── Optimisations ─────────────────────────────────────────────────────────────
# Intercept trivial Claude Code internal requests locally (saves API quota).
ENABLE_OPTIMIZATIONS=true

# Global switch for reasoning / thinking blocks.
# Set to false to strip thinking across all providers.
ENABLE_THINKING=true

# ── Logging ───────────────────────────────────────────────────────────────────
# LOG_LEVEL=info   # debug | info | warn | error
